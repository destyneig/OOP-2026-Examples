# --- Dependencies ---
# Never check in node_modules; it's huge and is recreated via 'npm install'
node_modules/
jspm_packages/

# --- Build Outputs ---
# We want the students to see the .ts files, not the auto-generated .js files
dist/
out/
build/
*.js
*.js.map
*.d.ts

# --- IDE / Editor Settings ---
# Exclude folder-specific settings that might differ between students
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# --- OS Specific ---
.DS_Store
Thumbs.db

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*